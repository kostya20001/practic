<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> test1 </title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #87CEEB 0%, #98D8E8 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* трава */
        .ground {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 200px;
            background: linear-gradient(180deg, #5c9e4d 0%, #2e7d32 100%);
            z-index: 1;
        }

        /* контейнер дома */
        .house {
            position: relative;
            width: 400px;
            height: 380px;
            margin-bottom: 60px;
            z-index: 10;
        }

        /* ДОМ */
        .house-base {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 250px;
            background: #d4b87a;    
            border: 3px solid #8b5a2b;
            border-radius: 8px 8px 0 0;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
            z-index: 1;
        }

        /* КРЫША */
        .roof {
            position: absolute;
            top: 0px;
            left: -20px;
            width: 0;
            height: 0;
            border-left: 220px solid transparent;
            border-right: 220px solid transparent;
            border-bottom: 140px solid #b53b2a;	  
            filter: drop-shadow(0 5px 8px rgba(0, 0, 0, 0.2));
            z-index: 2;
        }

        /* ДЫМОХОД */
        .chimney {
            position: absolute;
            top: 10px;
            right: 70px;
            width: 45px;
            height: 95px;
            background: #a05e3a;
            border: 2px solid #5a3a22;
            border-radius: 6px 6px 12px 12px;
            z-index: 3;
        }

        /* Верхняя часть дымохода */
        .chimney::before {
            content: "";
            position: absolute;
            top: -12px;
            left: -8px;
            width: 55px;
            height: 15px;
	    border: 2px solid #5a3a22;
            background: #a05e3a;
            border-radius: 8px;
        }

        /* ОКНО */
        .round-window {
            position: absolute;
            top: 250px;
            left: 60%;
            transform: translateX(-50%);
            width: 85px;
            height: 85px;
            background: #ffdd99;
            border-radius: 50%;
            border: 4px solid #b87c4a;
            z-index: 15;
            transition: transform 0.2s ease;
        }

        .round-window:hover {
            transform: translateX(-50%) scale(1.03);
        }

        /* ДВЕРЬ */
        .door {
            position: absolute;
            bottom: 0;
            left: 40px;
            width: 70px;
            height: 110px;
            background: #b87a4b;
            border-radius: 1px 1px 1px 1px;
            border: 2px solid #5a3a22;
            z-index: 20;
        }

        /* Ручка двери */
        .door::before {
            content: "";
            position: absolute;
            top: 50%;
            right: 12px;
            width: 10px;
            height: 10px;
            background: #ffcc88;
            border-radius: 50%;
            border: 1px solid #8b5a2b;
        }
       
    </style>
</head>
<body>

    <div class="ground"></div>
    
    <div class="house">
        <!-- Крыша -->
        <div class="roof"></div>
        
        <!-- Дымоход -->
        <div class="chimney"></div>
        
        <!-- Основание дома -->
        <div class="house-base"></div>
        
        <!-- окно -->
        <div class="round-window"></div>
        
        <!-- дверь -->
        <div class="door"></div>
 
    </div>
 
</body>
</html>
